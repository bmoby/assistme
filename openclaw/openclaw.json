{
  "meta": {
    "lastTouchedVersion": "2026.3.13",
    "lastTouchedAt": "2026-03-18T05:06:16.869Z"
  },
  "models": {
    "providers": {
      "anthropic": {
        "baseUrl": "https://api.anthropic.com",
        "apiKey": "${ANTHROPIC_API_KEY}",
        "models": [
          {
            "id": "claude-sonnet-4-6",
            "name": "Claude Sonnet 4.6"
          },
          {
            "id": "claude-haiku-4-5",
            "name": "Claude Haiku 4.5"
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-6"
      },
      "models": {
        "anthropic/claude-sonnet-4-6": {
          "alias": "sonnet",
          "params": {
            "cacheRetention": "short"
          }
        }
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "1h"
      },
      "compaction": {
        "mode": "safeguard"
      },
      "heartbeat": {
        "every": "30m"
      }
    },
    "list": [
      {
        "id": "copilote",
        "workspace": "~/.openclaw/agents/copilote"
      },
      {
        "id": "public",
        "workspace": "~/.openclaw/agents/public",
        "model": {
          "primary": "anthropic/claude-haiku-4-5"
        }
      },
      {
        "id": "formateur",
        "workspace": "~/.openclaw/agents/formateur"
      }
    ]
  },
  "bindings": [
    {
      "type": "route",
      "agentId": "copilote",
      "match": {
        "channel": "telegram",
        "accountId": "admin"
      }
    },
    {
      "type": "route",
      "agentId": "public",
      "match": {
        "channel": "telegram",
        "accountId": "public"
      }
    },
    {
      "type": "route",
      "agentId": "formateur",
      "match": {
        "channel": "discord",
        "accountId": "*"
      }
    }
  ],
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist",
      "streaming": "partial",
      "accounts": {
        "admin": {
          "dmPolicy": "pairing",
          "botToken": "${TELEGRAM_BOT_TOKEN}",
          "allowFrom": [
            "${TELEGRAM_ADMIN_CHAT_ID}"
          ],
          "groupPolicy": "allowlist",
          "streaming": "partial"
        },
        "public": {
          "dmPolicy": "open",
          "botToken": "${PUBLIC_BOT_TOKEN}",
          "allowFrom": [
            "*"
          ],
          "groupPolicy": "allowlist",
          "streaming": "partial"
        }
      },
      "defaultAccount": "admin"
    },
    "discord": {
      "enabled": true,
      "token": "${DISCORD_BOT_TOKEN}",
      "groupPolicy": "allowlist",
      "streaming": "off"
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "24988f0541c1046218fff269770a1782d9d0207278f520fa"
    }
  },
  "plugins": {
    "allow": [
      "supabase-tools",
      "telegram",
      "discord"
    ]
  }
}
