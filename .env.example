# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (Whisper transcription)
OPENAI_API_KEY=sk-...

# Telegram (Admin bot - your personal copilot)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_ADMIN_CHAT_ID=your-telegram-user-id

# Telegram (Public bot - Russian, for your audience)
PUBLIC_BOT_TOKEN=123456:ABC-DEF...

# Public bot links
PILOTE_NEURO_URL=https://pilotneuro.com
PORTAL_URL=
TELEGRAM_GROUP_URL=

# Discord
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-application-id
DISCORD_GUILD_ID=your-discord-server-id

# Instagram (Meta) - Phase 4
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# Redis (optional — cache disabled if not set)
REDIS_URL=redis://localhost:6379

# Embedding Server (optional — semantic search disabled if not set)
EMBEDDING_SERVER_URL=http://localhost:8090/embed

# TTS (voice responses)
# Model: "hd" for natural voice, empty for standard
TTS_MODEL=hd
# Voice: alloy, echo, fable, onyx, nova, shimmer
TTS_VOICE=nova

# Server
NODE_ENV=development
PORT=3000
