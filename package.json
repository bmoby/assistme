{
  "name": "assistme",
  "version": "1.0.0",
  "private": true,
  "description": "Personal AI assistant system - multi-bot architecture",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:discord": "pnpm -F @assistme/core build && pnpm -F @assistme/bot-discord dev",
    "build": "pnpm -r run build",
    "lint": "eslint packages/*/src/**/*.ts",
    "lint:fix": "eslint packages/*/src/**/*.ts --fix",
    "format": "prettier --write 'packages/*/src/**/*.ts'",
    "typecheck": "pnpm -F @assistme/core build && pnpm -r run typecheck",
    "seed:knowledge": "pnpm exec tsx scripts/seed-formation-knowledge.ts",
    "test": "vitest run --project core --project bot-discord --project bot-discord-quiz",
    "test:unit": "vitest run --project core --project bot-discord --project bot-discord-quiz",
    "test:integration": "vitest run --project core-integration --project bot-discord-integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --project core --project bot-discord --project bot-discord-quiz --coverage",
    "test:e2e": "vitest run --project e2e"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=7.0.0"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.99.0",
    "@vitest/coverage-v8": "^4.1.1",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "msw": "^2.12.14",
    "puppeteer": "^24.40.0",
    "tsx": "^4.21.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.1"
  }
}
